rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - CRICNINJA
     * Public-Read, Owner-Write model for Live Cricket Scoring, Player Profiles, and Leaderboards.
     */

    // --- GLOBAL HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- USER PROFILES & USERNAMES ---
    match /users/{userId} {
      allow get, list: if true; // Public for Leaderboards & Profiles
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /usernames/{username} {
      allow get, list: if true; // Public for availability check
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- MATCHES & SCORECARDS ---
    match /matches/{matchId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
      
      match /innings/{inningsId} {
        allow get, list: if true;
        allow create, update: if isSignedIn();
        allow delete: if false;

        match /overs/{overId} {
          allow get, list: if true;
          allow create, update: if isSignedIn();
          allow delete: if false;

          match /balls/{ballId} {
            allow get, list: if true;
            allow create, update: if isSignedIn();
            allow delete: if false;
          }
        }
      }
    }

    // --- TEAMS & PLAYERS ---
    match /teams/{teamId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /players/{playerId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }
  }
}